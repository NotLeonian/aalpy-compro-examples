alphabet = [0, 1]

P = [[{A}, {B}], [{C}, {D}]]


def accepts(word: tuple[int, ...]) -> bool:
    s = list(word)
    n = len(s)

    if n == 0:
        return False

    dp = [[[False, False] for _ in range(n + 1)] for _ in range(n)]

    for i, cur in enumerate(word):
        dp[i][1][cur] = True

    for i in range(2, n + 1):
        for j in range(n - i + 1):
            for k in range(1, i):
                for a in [0, 1]:
                    for b in [0, 1]:
                        if dp[j][k][a] and dp[j + k][i - k][b]:
                            dp[j][i][P[a][b]] = True

    return dp[0][n][1]
