from itertools import product

W = {W}

alphabet = list(range(1 << W))


def __is_black(s: list[int], i: int, j: int) -> bool:
    return (s[i] >> j) % 2 == 1


def __subtask(s: list[int], i: int, j: int) -> bool:
    for di, dj in product((0, 1), repeat=2):
        if not __is_black(s, i + di, j + dj):
            return True
    return False


def accepts(word: tuple[int, ...]) -> bool:
    s = list(word)
    H = len(s)

    for i in range(H - 1):
        for j in range(W - 1):
            if not __subtask(s, i, j):
                return False

    return True


MAX_LEN = 2


def iter_eq_words():
    for i in range(1, MAX_LEN + 1):
        for word in product(range(1 << W), repeat=i):
            yield word
