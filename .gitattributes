* text=auto

# Python
*.py   text eol=lf diff=python
*.pyi  text eol=lf diff=python
*.pyw  text eol=lf diff=python

# C / C++
*.c    text diff=cpp
*.cc   text diff=cpp
*.cpp  text diff=cpp
*.cxx  text diff=cpp
*.h    text diff=cpp
*.hh   text diff=cpp
*.hpp  text diff=cpp
*.hxx  text diff=cpp
*.ipp  text diff=cpp
*.tpp  text diff=cpp
*.ixx  text diff=cpp
*.cppm text diff=cpp

# CMake
CMakeLists.txt text eol=lf
*.cmake        text eol=lf

# Shell scripts
*.sh   text eol=lf
*.bash text eol=lf
*.zsh  text eol=lf

# Windows scripts
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Python / C++ generated files
*.pyc   binary
*.pyo   binary
*.pyd   binary
*.so    binary
*.dll   binary
*.dylib binary
*.a     binary
*.lib   binary
*.o     binary
*.obj   binary
*.exe   binary

# Common binary files
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.zip   binary
*.7z    binary
*.gz    binary
*.tar   binary

# ac-library
ac-library/** linguist-vendored
